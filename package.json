{
  "name": "clawcrew",
  "version": "0.1.0",
  "description": "Durable, review-first AI agent runtime with CLI-first workflows and messenger steering.",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "clawcrew": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js start",
    "dev": "tsx src/cli.ts start",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["ai", "multi-agent", "autonomous", "slack", "telegram", "sdlc", "orchestration"],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@slack/bolt": "^4.1.0",
    "grammy": "^1.35.0",
    "openai": "^4.80.0",
    "@google/generative-ai": "^0.22.0",
    "better-sqlite3": "^11.8.0",
    "commander": "^13.1.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0",
    "nanoid": "^5.1.0",
    "eventemitter3": "^5.0.1",
    "pino": "^9.6.0",
    "dotenv": "^16.5.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "tsx": "^4.19.0",
    "eslint": "^9.18.0",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
